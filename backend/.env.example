# Copia come .env e compila. NON committare .env (è in .gitignore).
# Su Render: imposta queste variabili in Environment del servizio.

# Porta (locale: 10000 | online: Render assegna PORT)
PORT=10000

# OpenAI (transcribe + text-to-speech)
OPENAI_API_KEY=

# Pupau chatbot
PUPAO_API_URL=https://api.pupau.ai
PUPAO_BOT_ID=
PUPAO_API_KEY=

# URL pubblico del backend (per generare gli URL degli audio)
# Locale: http://localhost:10000 | Online: https://www.agenticbad.com (o URL Render)
VITE_API_URL=http://localhost:10000
