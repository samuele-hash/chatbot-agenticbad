# Copia come .env e compila. NON committare .env (è in .gitignore).
# Su Render: imposta queste variabili in Environment del servizio.

# Porta (locale: 10000 | online: Render assegna PORT)
PORT=10000

# Google Cloud (Text-to-Speech + Speech-to-Text)
# Abilita "Cloud Text-to-Speech API" e "Cloud Speech-to-Text API" sul progetto.
GOOGLE_CLOUD_API_KEY=
# GOOGLE_TTS_LANGUAGE_CODE=it-IT
# Voce maschile naturale (Neural2): it-IT-Neural2-C
# GOOGLE_TTS_VOICE_NAME=it-IT-Neural2-C
# GOOGLE_STT_LANGUAGE_CODE=it-IT

# Pupau chatbot
PUPAO_API_URL=https://api.pupau.ai
PUPAO_BOT_ID=
PUPAO_API_KEY=

# Locale: http://localhost:10000 | Online: URL pubblico del backend su Render
VITE_API_URL=http://localhost:10000
